# Los medios son datos personales de clientes. Solo se sirven por public/media.php,
# que exige sesión de asesor o el token interno del agente.
#
# Hace falta porque en el deploy de "carpeta" (public_html/crm/) este directorio
# cuelga del docroot y sin esto sería alcanzable por URL.

# Apache 2.4
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>

# Apache 2.2
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
