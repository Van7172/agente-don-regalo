# CRM Don Regalo — MySQL local (XAMPP)
# En este entorno MySQL escucha en 3307 (ver C:\xampp\mysql\bin\my.ini)

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=donregalo_bd

# Tenant por defecto
CRM_TENANT_SLUG=don-regalo

# Shared secret agent ↔ CRM (header X-CRM-Token)
CRM_INTERNAL_TOKEN=dev-crm-token-change-me

# Sesión del panel (cookie JWT httpOnly)
SESSION_SECRET=cambia-este-secreto-largo-en-produccion

# URL del agente sandbox (outbox / envíos)
AGENT_BASE_URL=http://127.0.0.1:8001
AGENT_INTERNAL_TOKEN=dev-agent-token-change-me
