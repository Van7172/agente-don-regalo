# CRM Don Regalo — MySQL (local o remoto / producción)

# --- Local XAMPP ---
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3307

# --- Producción EasyPanel → MySQL del cliente ---
MYSQL_HOST=host.mysql.del.cliente
MYSQL_PORT=3306
MYSQL_USER=usuario_remoto
MYSQL_PASSWORD=
MYSQL_DATABASE=donregalo_bd

# Tenant por defecto
CRM_TENANT_SLUG=don-regalo

# Shared secret agent ↔ CRM (header X-CRM-Token) — mismo valor en sandbox
CRM_INTERNAL_TOKEN=cambia-este-token-seguro

# Sesión del panel (cookie JWT httpOnly)
SESSION_SECRET=cambia-este-secreto-largo-en-produccion

# URL pública del agente sandbox (outbox / envíos del asesor)
AGENT_BASE_URL=https://don-regalo-rags-app-agente-sandbox.XXXX.easypanel.host
AGENT_INTERNAL_TOKEN=cambia-este-token-agente
