# WhatsApp Cloud API (Meta)
WHATSAPP_TOKEN=EAAB...
WHATSAPP_PHONE_NUMBER_ID=1234567890
WHATSAPP_VERIFY_TOKEN=mi_verify_token_secreto
WHATSAPP_APP_SECRET=

# Base de datos CRM (SQLite local por defecto; Postgres en staging/prod)
DATABASE_URL=sqlite+aiosqlite:///./sandbox.db

# Tenant por defecto (single-tenant v1)
DEFAULT_TENANT_SLUG=don-regalo
DEFAULT_TENANT_NAME=Don Regalo

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Gates del bot (equivalente a labels Chatwoot)
BOT_ACTIVE_LABEL=agente_on
HUMAN_SUPPORT_LABEL=soporte_humano
ALERT_WEBHOOK_URL=

# Buffer y typing (defaults más ágiles que legacy)
BUFFER_SECONDS=2.5
TYPING_SECONDS_PER_CHAR=0.01
TYPING_MIN_DELAY=0.2
TYPING_MAX_DELAY=1.2
MEMORY_WINDOW_HOURS=12
MEMORY_MAX_MESSAGES=15
MAX_TOOL_ROUNDS=4

# Qdrant
QDRANT_URL=https://tu-qdrant.easypanel.host
QDRANT_API_KEY=tu_qdrant_api_key
QDRANT_COLLECTION=productos
EMBED_MODEL=text-embedding-3-small
EMBED_DIM=1536
SEMANTIC_LIMIT=6
KB_COLLECTION=respuestas_equipo
KB_LIMIT=3
KB_MIN_SCORE=0.5
CACHE_TTL_SECONDS=3600
DONREGALO_API_BASE=https://donregalo.pe/clienteApiApp/api
PDF_MAX_CHARS=30000
