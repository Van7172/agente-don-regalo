# URL base de tu instancia Chatwoot (sin barra final)
CHATWOOT_URL=https://app.chatwoot.com

# Token de acceso de la cuenta (Settings → API Access Token)
CHATWOOT_API_TOKEN=your_api_access_token_here

# ID numérico de la cuenta en Chatwoot
CHATWOOT_ACCOUNT_ID=1

# API key de OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here

# Modelo a usar
OPENAI_MODEL=gpt-4o-mini

# Etiqueta de Chatwoot requerida para que el bot responda
BOT_ACTIVE_LABEL=agente_on
