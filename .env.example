# URL base de tu instancia Chatwoot (sin barra final)
CHATWOOT_URL=https://app.chatwoot.com

# Token de acceso de la cuenta (Settings → API Access Token)
CHATWOOT_API_TOKEN=your_api_access_token_here

# ID numérico de la cuenta en Chatwoot
CHATWOOT_ACCOUNT_ID=1

# API key de OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here

# Modelo a usar
OPENAI_MODEL=gpt-4o-mini

# Etiqueta de Chatwoot requerida para que el bot responda
BOT_ACTIVE_LABEL=agente_on

# Segundos de silencio antes de procesar (agrupa mensajes seguidos del cliente)
BUFFER_SECONDS=4

# Delay "humano" entre burbujas (segundos por carácter, con mínimo y máximo)
TYPING_SECONDS_PER_CHAR=0.03
TYPING_MIN_DELAY=0.8
TYPING_MAX_DELAY=4.0
