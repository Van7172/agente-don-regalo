# URL base de tu instancia Chatwoot (sin barra final)
CHATWOOT_URL=https://app.chatwoot.com

# Token de acceso de la cuenta (Settings → API Access Token)
CHATWOOT_API_TOKEN=your_api_access_token_here

# ID numérico de la cuenta en Chatwoot
CHATWOOT_ACCOUNT_ID=1

# API key de OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here

# Modelo a usar
OPENAI_MODEL=gpt-4o-mini

# Etiqueta de Chatwoot requerida para que el bot responda
BOT_ACTIVE_LABEL=agente_on

# Evolution API — para enviar imágenes directo a WhatsApp
EVOLUTION_API_URL=https://tu-evolution.easypanel.host
EVOLUTION_API_KEY=tu_api_key_de_evolution
EVOLUTION_INSTANCE=nombre_de_tu_instancia

# Segundos de silencio antes de procesar (agrupa mensajes seguidos del cliente)
BUFFER_SECONDS=4

# Delay "humano" entre burbujas (segundos por carácter, con mínimo y máximo)
TYPING_SECONDS_PER_CHAR=0.03
TYPING_MIN_DELAY=0.8
TYPING_MAX_DELAY=4.0

# Memoria de corto plazo: ventana del historial (horas) y tope de mensajes
MEMORY_WINDOW_HOURS=24
MEMORY_MAX_MESSAGES=30

# ── Qdrant (búsqueda semántica de productos) ──────────────────────────────────
QDRANT_URL=https://tu-qdrant.easypanel.host
QDRANT_API_KEY=tu_qdrant_api_key
QDRANT_COLLECTION=productos
# Modelo de embeddings y su dimensión (text-embedding-3-small = 1536)
EMBED_MODEL=text-embedding-3-small
EMBED_DIM=1536
# Base de la API de donregalo (para el job de sincronización)
DONREGALO_API_BASE=https://donregalo.pe/clienteApiApp/api